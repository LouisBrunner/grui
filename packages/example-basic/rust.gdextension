[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../../target/debug/libgrui_example_basic.so"
linux.release.x86_64 =   "res://../../target/release/libgrui_example_basic.so"
windows.debug.x86_64 =   "res://../../target/debug/basgrui_example_basic.dll"
windows.release.x86_64 = "res://../../target/release/basgrui_example_basic.dll"
macos.debug =            "res://../../target/debug/libgrui_example_basic.dylib"
macos.release =          "res://../../target/release/libgrui_example_basic.dylib"
macos.debug.arm64 =      "res://../../target/debug/libgrui_example_basic.dylib"
macos.release.arm64 =    "res://../../target/release/libgrui_example_basic.dylib"
